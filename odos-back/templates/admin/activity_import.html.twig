{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Importer des activités (Excel / CSV){% endblock %}

{% block main %}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'danger' ? 'danger' : (type == 'warning' ? 'warning' : (type == 'success' ? 'success' : 'info')) }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Téléversement</div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_activities_import') }}">

                        <div class="mb-3">
                            <label for="file" class="form-label">Fichier (.xlsx, .xls, .ods ou .csv) — max 5 Mo</label>
                            <input class="form-control" type="file" name="file" id="file" accept=".xlsx,.xls,.ods,.csv" required>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" value="1" id="create_missing_categories" name="create_missing_categories" checked>
                            <label class="form-check-label" for="create_missing_categories">
                                Créer automatiquement les catégories manquantes
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-upload me-1"></i> Lancer l'import
                            </button>
                            <a class="btn btn-outline-secondary" href="{{ path('admin_activities_import_template') }}">
                                <i class="fa fa-file-csv me-1"></i> Télécharger le modèle CSV
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            {% if result is not null and result.fatalError is null %}
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-white fw-semibold">Résultat</div>
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <div class="border rounded p-3">
                                    <div class="text-muted small">Créées</div>
                                    <div class="fs-4 fw-semibold text-success">{{ result.createdCount }}</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="border rounded p-3">
                                    <div class="text-muted small">Ignorées</div>
                                    <div class="fs-4 fw-semibold text-warning">{{ result.skippedCount }}</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="border rounded p-3">
                                    <div class="text-muted small">Erreurs</div>
                                    <div class="fs-4 fw-semibold text-danger">{{ result.errors|length }}</div>
                                </div>
                            </div>
                        </div>

                        {% if result.errors|length > 0 %}
                            <h6 class="fw-semibold">Détails des erreurs</h6>
                            <ul class="mb-0 small">
                                {% for err in result.errors %}
                                    <li>{{ err }}</li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">Format attendu</div>
                <div class="card-body">
                    <p class="small mb-2">La première ligne doit contenir les en-têtes de colonnes (ordre libre, insensible à la casse). Colonnes obligatoires en gras.</p>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Colonne</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td><strong>name</strong></td><td>Nom de l'activité</td></tr>
                                <tr><td><strong>description</strong></td><td>Description longue</td></tr>
                                <tr><td><strong>latitude</strong></td><td>−90 à 90</td></tr>
                                <tr><td><strong>longitude</strong></td><td>−180 à 180</td></tr>
                                <tr><td><strong>category</strong></td><td>Nom de la catégorie</td></tr>
                                <tr><td>city</td><td>Ville</td></tr>
                                <tr><td>price</td><td>Prix en EUR</td></tr>
                                <tr><td>image_url</td><td>URL de l'image</td></tr>
                                <tr><td>date_start</td><td>Y-m-d ou Y-m-d H:i</td></tr>
                                <tr><td>date_end</td><td>Y-m-d ou Y-m-d H:i</td></tr>
                                <tr><td>is_published</td><td>1/0, oui/non — défaut 1</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="alert alert-info small mb-0">
                        Astuce : pour ajouter ou modifier la photo d'une activité, ouvre la fiche d'activité et utilise le champ <em>Photo (téléversement)</em>.
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
