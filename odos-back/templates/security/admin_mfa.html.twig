{% extends 'base.html.twig' %}

{% block title %}Odos Admin - MFA{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h1 class="h3 mb-3 font-weight-normal">Odos Admin - Vérification MFA</h1>

            <div class="alert alert-secondary">
                <div class="fw-semibold mb-1">Étapes</div>
                <div>
                    <strong>1.</strong> Google Authenticator (TOTP)
                    {% if totp_verified %}
                        <span class="badge text-bg-success ms-2">OK</span>
                    {% else %}
                        <span class="badge text-bg-secondary ms-2">En attente</span>
                    {% endif %}
                </div>
                <div class="mt-1">
                    <strong>2.</strong> SMS OTP
                    {% if totp_verified %}
                        <span class="badge text-bg-secondary ms-2">À valider</span>
                    {% else %}
                        <span class="badge text-bg-secondary ms-2">Bloqué</span>
                    {% endif %}
                </div>
            </div>
            <div class="mb-3">
                <a class="btn btn-sm btn-outline-dark" href="{{ path('app_admin_mfa_totp_setup') }}">
                    Configurer Google Authenticator (QR)
                </a>
            </div>

            {% if error %}
                <div class="alert alert-danger">{{ error }}</div>
            {% endif %}

            {% if info %}
                <div class="alert alert-success" role="status">{{ info }}</div>
            {% endif %}

            <form method="post" id="admin-mfa-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_mfa') }}">

                {% if totp_verified %}
                    <div class="alert alert-success mt-3">
                        Google Authenticator validé.
                        <span class="text-muted small ms-2">Étape SMS à compléter.</span>
                    </div>
                {% else %}
                    <div class="mt-3">
                        <label for="inputTotpCode" class="form-label">Code Google Authenticator (TOTP)</label>
                        <input type="text"
                               name="totp_code"
                               id="inputTotpCode"
                               class="form-control"
                               inputmode="numeric"
                               pattern="[0-9]{6}"
                               maxlength="6"
                               autocomplete="one-time-code"
                               placeholder="6 chiffres">
                        <div class="form-text">
                            Ouvrez Google Authenticator et saisissez le code à 6 chiffres (toutes les ~30 secondes).
                        </div>
                    </div>
                {% endif %}

                <div class="mt-3">
                    <label for="inputSmsCode" class="form-label">Code SMS</label>
                    <input type="text"
                           name="sms_code"
                           id="inputSmsCode"
                           class="form-control"
                           inputmode="numeric"
                           pattern="[0-9]{6}"
                           maxlength="6"
                           autocomplete="one-time-code"
                           placeholder="6 chiffres"
                           {% if not totp_verified %}disabled aria-disabled="true"{% endif %}>
                    <div class="form-text">
                        {% if masked_phone %}
                            Numero cible: {{ masked_phone }}
                        {% else %}
                            Aucun numero configure pour cet admin.
                        {% endif %}
                        {% if not totp_verified %}
                            <span class="text-muted d-block mt-1">Validez d’abord l’étape Google Authenticator.</span>
                        {% endif %}
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 flex-wrap">
                    {% if not totp_verified %}
                        <button class="btn btn-secondary" type="submit" name="action" value="validate_totp">
                            Valider Google Authenticator
                        </button>
                    {% endif %}

                    <button class="btn btn-outline-primary"
                            type="submit"
                            name="action"
                            value="send_sms"
                            {% if not totp_verified %}disabled aria-disabled="true"{% endif %}>
                        Envoyer le code SMS
                    </button>

                    <button class="btn btn-primary"
                            type="submit"
                            name="action"
                            value="validate"
                            {% if not totp_verified %}disabled aria-disabled="true"{% endif %}>
                        Valider MFA admin
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
