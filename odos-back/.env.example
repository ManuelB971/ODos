
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Local (sans Docker):
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
#
# Docker (via docker-compose.yml — le hostname est le nom du service):
DATABASE_URL="postgresql://odos:odos_secret@postgres:5432/odos?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=changeme
###< lexik/jwt-authentication-bundle ###

###> app/admin-mfa ###
# Knowledge factor (PIN) + possession factor (TOTP secret, Base32)
ADMIN_MFA_PIN=123456
ADMIN_MFA_TOTP_SECRET=JBSWY3DPEHPK3PXP
ADMIN_MFA_TOTP_ISSUER=ODos

# Set to 1 to enforce browser biometric verification (WebAuthn userVerification)
ADMIN_MFA_REQUIRE_BIOMETRIC=1

# Optional relying party id for WebAuthn (defaults to current host)
ADMIN_WEBAUTHN_RP_ID=localhost
###< app/admin-mfa ###

###> app/admin-totp-sms-mfa ###
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Windows / PHP sans CA: telecharger https://curl.se/ca/cacert.pem puis chemin absolu ou relatif au projet (ex: config/cacert.pem)
TWILIO_CAINFO=
###< app/admin-totp-sms-mfa ###

###> app/llm-recommendations ###
LLM_PROVIDER=ollama
LLM_BASE_URL=http://llm:11434
LLM_MODEL=qwen2.5:1.5b
LLM_TIMEOUT=3
LLM_TOP_K=15
LLM_CANDIDATE_MAX=20
LLM_ENABLED=true
LLM_CACHE_TTL_SECONDS=1800
###< app/llm-recommendations ###
