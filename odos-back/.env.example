
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# CLI sur la machine hôte (Docker expose 5432) :
DATABASE_URL="postgresql://odos:odos_secret@127.0.0.1:5432/odos?serverVersion=16&charset=utf8"
# Dans le conteneur php uniquement : hostname postgres au lieu de 127.0.0.1
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
# Dev : localhost + réseau local (Expo / téléphone). Prod : odos-config/env.prod.example
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|192\.168\.[0-9]+\.[0-9]+|10\.[0-9]+\.[0-9]+\.[0-9]+)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> app/oauth-social ###
# IDs client Google autorisés (séparés par des virgules) — web + Android + iOS Expo
GOOGLE_OAUTH_CLIENT_IDS=
# Bundle ID iOS / Service ID Sign in with Apple (ex. com.odos.front)
APPLE_CLIENT_ID=
###< app/oauth-social ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=changeme
# Access token (secondes) — 900 = 15 min recommandé en prod.
JWT_TOKEN_TTL=900
# Refresh token (secondes) — 2592000 = 30 jours.
JWT_REFRESH_TTL=2592000
###< lexik/jwt-authentication-bundle ###

###> app/admin-mfa ###
# 0 en dev local ; 1 en prod
ADMIN_MFA_ENABLED=0

# Knowledge factor (PIN) + possession factor (TOTP secret, Base32)
ADMIN_MFA_PIN=123456
ADMIN_MFA_TOTP_SECRET=JBSWY3DPEHPK3PXP
ADMIN_MFA_TOTP_ISSUER=ODos

# Set to 1 to enforce browser biometric verification (WebAuthn userVerification)
ADMIN_MFA_REQUIRE_BIOMETRIC=0

# Optional relying party id for WebAuthn (defaults to current host)
ADMIN_WEBAUTHN_RP_ID=localhost
###< app/admin-mfa ###

###> app/admin-totp-sms-mfa ###
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Windows / PHP sans CA: telecharger https://curl.se/ca/cacert.pem puis chemin absolu ou relatif au projet (ex: config/cacert.pem)
TWILIO_CAINFO=
###< app/admin-totp-sms-mfa ###

###> app/llm-recommendations ###
LLM_PROVIDER=ollama
LLM_BASE_URL=http://llm:11434
LLM_MODEL=qwen2.5:1.5b
LLM_TIMEOUT=3
LLM_TOP_K=15
LLM_CANDIDATE_MAX=20
LLM_ENABLED=true
LLM_CACHE_TTL_SECONDS=1800
###< app/llm-recommendations ###
