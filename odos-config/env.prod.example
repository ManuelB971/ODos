# Copier sur le VPS : ~/odos-config/.env
# Ne jamais commiter le fichier réel (secrets).

###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=REMPLACER_32_CARACTERES_ALEATOIRES
APP_SHARE_DIR=var/share
# Reverse proxy (Nginx hôte) — permet HTTPS / X-Forwarded-*
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR,172.16.0.0/12
###< symfony/framework-bundle ###

###> symfony/routing ###
# Sans domaine : http://167.86.75.36:8000
# Avec API    : https://api.odos-api.com
DEFAULT_URI=https://api.odos-api.com
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL=postgresql://odos:REMPLACER_MOT_DE_PASSE@postgres:5432/odos?serverVersion=16&charset=utf8
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

###> nelmio/cors-bundle ###
# Admin web + landing (l'APK native n'utilise pas CORS)
CORS_ALLOW_ORIGIN='^https?://(www\.)?odos\.world$|^https?://api\.odos-api\.com$|^https?://167\.86\.75\.36(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=REMPLACER
JWT_TOKEN_TTL=900
JWT_REFRESH_TTL=2592000
###< lexik/jwt-authentication-bundle ###

###> app/admin-mfa ###
ADMIN_MFA_ENABLED=1
ADMIN_MFA_PIN=REMPLACER
ADMIN_MFA_TOTP_SECRET=REMPLACER_BASE32
ADMIN_MFA_TOTP_ISSUER=ODos
ADMIN_MFA_REQUIRE_BIOMETRIC=1
ADMIN_WEBAUTHN_RP_ID=api.odos-api.com
###< app/admin-mfa ###

###> app/llm-recommendations ###
LLM_ENABLED=false
###< app/llm-recommendations ###

# Port HTTP exposé par nginx sur le VPS
APP_HTTP_PORT=8000
