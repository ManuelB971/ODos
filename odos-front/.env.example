# ── Dev local (Expo Go, expo start, expo run:android) ──
# Émulateur Android : localhost:8000
# Téléphone sur le même Wi‑Fi : http://192.168.x.x:8000 (IP du PC + port Docker nginx)
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── APK / AAB pointant vers le VPS prod ──
# L'URL est figée au build EAS (odos-front/eas.json, profils preview | production).
# Ne pas s'appuyer sur ce fichier pour un build EAS prod.
# EXPO_PUBLIC_API_URL=http://167.86.75.36:8000
